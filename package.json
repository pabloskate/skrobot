{
  "name": "skrobot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/mobile"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck:mobile": "npm --workspace mobile run typecheck",
    "typecheck:animations": "npm --prefix skrobot-animations run typecheck",
    "check": "npm run lint && npm test && npm run typecheck:mobile && npm run typecheck:animations && npm run build",
    "mobile:start": "npm --workspace mobile run start",
    "mobile:ios": "npm --workspace mobile run ios",
    "mobile:android": "npm --workspace mobile run android",
    "native:parity-status": "node scripts/native-parity-status.mjs",
    "test:watch": "vitest",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "db:migrate:local": "wrangler d1 migrations apply skrobot --local",
    "db:migrate:remote": "wrangler d1 migrations apply skrobot --remote",
    "db:migrations:list:local": "wrangler d1 migrations list skrobot --local",
    "db:migrations:list:remote": "wrangler d1 migrations list skrobot --remote",
    "cf-typegen": "wrangler types /private/tmp/skrobot-cloudflare-env.d.ts --env-interface CloudflareEnv --include-runtime false"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "next": "^16.2.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
