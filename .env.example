# --- `next dev` env (copy to .env.local) ---

# Server-side key used by POST /api/live-token to mint ephemeral Live tokens.
# In production this is a Cloudflare secret: npx wrangler secret put GEMINI_API_KEY
# For `npm run preview` (wrangler), put it in .dev.vars instead (same format).
GEMINI_API_KEY=

# DEV ONLY browser fallback: lets the client talk to the Live API directly when
# /api/live-token isn't configured. Anything NEXT_PUBLIC_* ships to the client —
# never use a key you care about here.
NEXT_PUBLIC_GEMINI_API_KEY=
